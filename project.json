{
  "name": "nx-uv",
  "$schema": "./node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist",
        "main": "src/index.ts",
        "tsConfig": "tsconfig.lib.json",
        "assets": [
          "*.md",
          {
            "input": "./src",
            "glob": "**/!(*.ts)",
            "output": "./src"
          },
          {
            "input": "./src",
            "glob": "**/*.d.ts",
            "output": "./src"
          },
          "generators.json",
          "executors.json"
        ]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.lib.json --noEmit && tsc -p tsconfig.spec.json --noEmit"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist"
      }
    },
    "format-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx format:check --all"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "vitest.config.mts"
      }
    },
    "test-unit": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "vitest.unit.config.mts"
      }
    },
    "test-integration": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "vitest.integration.config.mts"
      }
    },
    "test-e2e": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "vitest.e2e.config.mts"
      }
    },
    "test-coverage": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage"],
      "options": {
        "configFile": "vitest.coverage.config.mts",
        "reportsDirectory": "coverage"
      }
    },
    "coverage-badge": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "test-coverage"],
      "options": {
        "command": "node dist/src/tools/coverage-badge.js --summary coverage/coverage-summary.json --output .github/badges/coverage.json"
      }
    },
    "llms-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/generate-llms.cjs"
      }
    },
    "llms-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/check-llms.cjs"
      }
    },
    "quality-local": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx run nx-uv:format-check && pnpm nx run nx-uv:llms-check && pnpm nx run-many -t lint,typecheck,test-unit,test-integration -p nx-uv --nxBail --outputStyle=static"
      }
    },
    "quality-ci": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx run nx-uv:format-check && pnpm nx run nx-uv:llms-check && pnpm nx run-many -t lint,typecheck,test-unit,test-integration,test-e2e,test-coverage,build -p nx-uv --nxBail --outputStyle=static"
      }
    }
  }
}
