{
  "$schema": "https://json-schema.org/schema",
  "$id": "IntegrationGenerator",
  "title": "uv integration generator",
  "type": "object",
  "properties": {
    "template": {
      "type": "string",
      "enum": [
        "alternative-indexes",
        "aws-lambda",
        "coiled",
        "dependency-bots",
        "docker",
        "fastapi",
        "github",
        "gitlab",
        "jupyter",
        "marimo",
        "pre-commit",
        "pytorch"
      ]
    },
    "project": {
      "type": "string",
      "description": "Optional Nx project receiving template files."
    },
    "directory": {
      "type": "string",
      "description": "Optional directory to write integration files into when no project is provided."
    },
    "backend": {
      "type": "string",
      "description": "PyTorch backend selector for template=pytorch.",
      "enum": ["cuda", "rocm", "cpu"],
      "default": "cuda"
    },
    "includeNotebook": {
      "type": "boolean",
      "description": "When template=pytorch, include notebook scaffolding files.",
      "default": true
    },
    "includeDocker": {
      "type": "boolean",
      "description": "When template=pytorch, include NVIDIA inference Docker/Compose assets (cuda only). Defaults to true for backend=cuda, false otherwise."
    },
    "overwrite": {
      "type": "boolean",
      "default": false
    },
    "skipFormat": {
      "type": "boolean",
      "default": false
    }
  },
  "required": ["template"],
  "additionalProperties": false
}
